# Оптимизированный под задачу конфиг (см. eval/REPORT-optimization.md).
# Реальный .env — в .gitignore. Прод-значения дублируются в deploy/webchat-local.service.
OLLAMA_MODEL=qwen2.5-coder:3b
OLLAMA_URL=http://127.0.0.1:11434/api/chat
RAG_URL=http://127.0.0.1:8100

# Ручки оптимизации (перебирались через eval/optimize_eval.py):
PROMPT_VARIANT=copyfirst      # baseline | copyfirst (copy-first + few-shot цитата)
RAG_K_AFTER=6                 # сколько чанков после реранка в промпт
OLLAMA_NUM_CTX=3072           # окно контекста Ollama (дефолт 2048 обрезал бы чанки)
OLLAMA_NUM_PREDICT=384        # кап токенов ответа
OLLAMA_TIMEOUT=270            # httpx-таймаут одного вызова (< nginx 300 → нет 504)
GROUNDED_RETRY=0             # 0 на проде: без второй генерации при пустых цитатах
                             #   (иначе 2×генерация > nginx timeout). 1 — для eval.
