# Пример продакшн-конфига фронта. Реальный файл — frontend/.env.production
# (в .gitignore, не коммитится). Скопируйте и подставьте значения при деплое.

# В проде фронт отдаётся same-origin за nginx на поддомене → /chat зовётся
# относительно текущего хоста (пустая база), а не localhost:8000.
VITE_API_BASE=

# Gate-токен для /chat, проверяется nginx. ВНИМАНИЕ: это VITE_-переменная —
# Vite вшивает её в публичный JS-бандл, поэтому она НЕ настоящий секрет, а лишь
# отсекает случайный/прямой абьюз прокси локальной модели. Реальная защита —
# rate-limit.
VITE_CHAT_TOKEN=<подставить-при-деплое>
